# Normalize line endings: store LF in repo, auto-convert in working tree.
* text=auto eol=lf

# Treat binaries as binary (no eol conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.mp3 binary
*.wav binary
*.m4a binary
*.mp4 binary
*.woff binary
*.woff2 binary
*.pdf binary
