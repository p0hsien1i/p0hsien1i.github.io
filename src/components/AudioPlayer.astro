---
interface Props {
  title: string;
  src: string;
  image?: string;
}
const { title, src, image } = Astro.props;
---

<div class="audioclip card">
  {image && <img class="ac-img" src={image} alt={title} loading="lazy" />}
  <div class="ac-body">
    <div class="ac-title">{title}</div>
    <audio class="ac-audio" controls preload="none" src={src}></audio>
  </div>
</div>

<style>
  .audioclip {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    height: 100%;
  }
  .audioclip:hover {
    transform: none;
    box-shadow: var(--shadow-2);
    border-color: var(--border);
  }
  .ac-img {
    width: 100%;
    max-height: 160px;
    object-fit: contain;
    border-radius: var(--radius-sm);
    background: var(--surface-sunken);
  }
  .ac-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: auto;
  }
  .ac-title {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .ac-audio {
    width: 100%;
    height: 38px;
  }
</style>
