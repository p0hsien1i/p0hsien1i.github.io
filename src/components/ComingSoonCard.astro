---
interface Props {
  title: string;
  items?: string[];
}
const { title, items = [] } = Astro.props;
---

<div class="card soon">
  <span class="soon-chip">即將推出</span>
  <h3 class="soon-title">{title}</h3>
  {
    items.length > 0 && (
      <ul class="soon-list">
        {items.map((i) => (
          <li>{i}</li>
        ))}
      </ul>
    )
  }
</div>

<style>
  .soon {
    position: relative;
    padding: var(--space-5);
    height: 100%;
    background: var(--bg-subtle);
    border-style: dashed;
  }
  .soon:hover {
    transform: none;
    box-shadow: var(--shadow-1);
    border-color: var(--border-strong);
  }
  .soon-chip {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    background: var(--ume-500);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
  .soon-title {
    margin-top: var(--space-3);
    color: var(--text-muted);
  }
  .soon-list {
    margin-top: var(--space-3);
    padding-left: 1.1em;
    color: var(--text-faint);
    font-size: 0.92rem;
    line-height: 1.9;
  }
  .soon-list li::marker {
    content: "▲ ";
    color: var(--rice-400);
  }
</style>
