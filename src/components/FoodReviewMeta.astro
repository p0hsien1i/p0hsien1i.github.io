---
import StarRating from "./StarRating.astro";
import MapEmbed from "./MapEmbed.astro";

interface FoodReview {
  location: string;
  address?: string;
  mapEmbed?: string;
  ratings: {
    transport: number;
    ambience: number;
    service: number;
    taste: number;
    price: number;
  };
}
interface Props {
  foodReview: FoodReview;
}
const { foodReview } = Astro.props;
---

<div class="foodmeta card">
  <div class="fm-loc">
    <span class="fm-pin" aria-hidden="true">📍</span>
    <div>
      <strong>{foodReview.location}</strong>
      {foodReview.address && <div class="fm-addr">{foodReview.address}</div>}
    </div>
  </div>
  <StarRating ratings={foodReview.ratings} />
</div>
{foodReview.mapEmbed && <MapEmbed src={foodReview.mapEmbed} label={foodReview.location} />}

<style>
  .foodmeta {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    margin: var(--space-5) 0;
  }
  .fm-loc {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .fm-pin {
    font-size: 1.2rem;
  }
  .fm-addr {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
</style>
