---
import Logo from "./Logo.astro";
import SocialLinks from "./SocialLinks.astro";
import { site, navLinks } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container container-wide footer-inner">
    <div class="col brandcol">
      <a class="brand logo-hover" href="/">
        <Logo size={40} />
        <span class="wordmark">{site.name}</span>
      </a>
      <p class="blurb">{site.tagline}</p>
    </div>

    <nav class="col" aria-label="頁尾選單">
      <h2 class="col-title">逛逛</h2>
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="col">
      <h2 class="col-title">找我</h2>
      <SocialLinks variant="onNori" />
    </div>
  </div>

  <div class="container container-wide copyright">
    <span>© {year} {site.name} · Designed by {site.author}</span>
    <a class="totop" href="#top">回到頂端 ↑</a>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-10);
    background: var(--nori-800);
    color: #f2ece0;
    padding-top: var(--space-8);
  }
  :root[data-theme="dark"] .footer {
    background: var(--nori-900);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.4fr;
    gap: var(--space-7);
    padding-bottom: var(--space-7);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: #fff;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
  }
  .blurb {
    margin-top: var(--space-3);
    color: rgba(242, 236, 224, 0.72);
    font-size: 0.95rem;
    line-height: 1.8;
    max-width: 40ch;
  }
  .col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .col-title {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rice-300);
    margin-bottom: var(--space-2);
  }
  nav.col a {
    color: rgba(242, 236, 224, 0.82);
    text-decoration: none;
    font-size: 0.95rem;
    width: fit-content;
  }
  nav.col a:hover {
    color: #fff;
    text-decoration: underline;
  }
  .copyright {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-4);
    padding-bottom: var(--space-5);
    border-top: 1px solid rgba(242, 236, 224, 0.14);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: rgba(242, 236, 224, 0.6);
  }
  .totop {
    color: var(--rice-300);
    text-decoration: none;
  }
  .totop:hover {
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
