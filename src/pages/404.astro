---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
---

<BaseLayout title="找不到頁面 (404)">
  <Nav />
  <main class="container nf">
    <Logo size={96} />
    <h1>404</h1>
    <p>這顆飯糰被吃掉了 🍙 —— 找不到你要的頁面。</p>
    <div class="nf-cta">
      <a class="btn btn-primary" href="/">回首頁</a>
      <a class="btn btn-secondary" href="/blog">看部落格</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .nf {
    text-align: center;
    padding-block: var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    min-height: 50vh;
    justify-content: center;
  }
  .nf h1 {
    font-size: clamp(3rem, 2rem + 6vw, 5rem);
  }
  .nf p {
    color: var(--text-muted);
  }
  .nf-cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
